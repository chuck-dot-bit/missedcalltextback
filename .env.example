# ─────────────────────────────────────────────
# TWILIO CREDENTIALS
# Get these from: https://console.twilio.com
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+16045550000

# ─────────────────────────────────────────────
# OWNER NOTIFICATION
# Where to alert YOU when a missed call fires
# ─────────────────────────────────────────────
OWNER_PHONE=+16045559999
OWNER_EMAIL=you@yourdomain.com

# ─────────────────────────────────────────────
# AI CONVERSATION (OPTIONAL)
# Remove this line to use static SMS replies only
# Get key from: https://console.anthropic.com
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# CLIENT / BUSINESS CONFIG
# ─────────────────────────────────────────────
BUSINESS_NAME=Vancouver HVAC Pro
BUSINESS_PHONE=+16045550000
BOOKING_LINK=https://calendly.com/your-business
BUSINESS_HOURS=Mon-Fri 8am-5pm

# ─────────────────────────────────────────────
# OPTIONAL: WEBHOOK SECRET
# Add this to validate Twilio webhook signatures
# ─────────────────────────────────────────────
# TWILIO_WEBHOOK_SECRET=your_webhook_secret
